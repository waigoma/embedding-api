# Image source
# ghcr.io/<owner>/<repo>-nvidia:<tag>
# ghcr.io/<owner>/<repo>-amd:<tag>
EMBEDDING_IMAGE=ghcr.io/<owner>/<repo>-amd:latest

# Device mode: auto|cpu|gpu|cuda
DEVICE_MODE=auto

# Optional Hugging Face token (for private/gated repos)
HF_TOKEN=

# Optional upstream OpenAI-compatible chat backend (for /v1/chat/completions)
# Example: http://localhost:11434/v1  or  http://localhost:8000/v1
LLM_PROXY_BASE_URL=
LLM_PROXY_API_KEY=
LLM_PROXY_TIMEOUT_SEC=120
